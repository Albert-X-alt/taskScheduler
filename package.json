{
  "name": "matrix-task",
  "version": "1.0.0",
  "description": "Albert's task scheduler",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "pack:exe": "vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.albert.matrixtask",
    "productName": "MatrixTask",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    }
  }
}
